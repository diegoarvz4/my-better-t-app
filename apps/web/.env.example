# Better-Auth
# Secret must be at least 32 characters
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# CORS / trusted origin for the web app
CORS_ORIGIN=http://localhost:3001

# Database (libSQL / SQLite). Use a local file URL for development.
DATABASE_URL=file:../../local.db

# Social login providers (optional).
# Providers are only registered when BOTH the id and secret are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
